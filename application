import tkinter as tk
from tkinter import ttk


def zeige_startfenster(parent, titel, willkommen):
    # 1. Ein neues, übergeordnetes Fenster erstellen
    fenster = tk.Toplevel(parent)
    fenster.title(titel)
    fenster.configure(bg="#87A177")               # farbe mit der configure methode einstellen
    fenster.geometry("800x600") 
    fenster.transient(parent)                       # Window kann nicht angeklickt werden, solange das kleine Fenster offen ist
    fenster.grab_set()
    
    text_label = tk.Label(fenster, text=willkommen, bg="#444031", fg="white", font=("Courier", 12), justify="center")
    text_label.pack(pady=30, padx=15, expand=True)  # pack platziert widget auf die GuI
    
    ok_button = tk.Button(fenster, text="yeah!", bg="#87A177", fg="#444031", font=("Courier", 10, "bold"), width=10, command=fenster.destroy)        # mit destoy wird das fenster geschlossen
    ok_button.pack(pady=5, anchor="n")



class Window(tk.Tk):                                # Die erste class erstellt mir mein Fenster
    def __init__(self, title, size):
        
        # Haupteinstellungen
        super().__init__()
        self.title("SpiderWeb")                           # String Titel des Programmes
        self.geometry("1000x600")       # transform into String 
        self.minsize(size[0],size[1])               # Fenter-Mindestgröße
        self.configure(background="white")
        self.resizable(width=False, height=False)   # Fenstergröße kann nicht verändert werden
        
        # Widgets
        self.habits = Habit_Frame(self)             # Window ist die Parentclass von Habit_Frame und ToDo_Frame
        self.toDos = ToDo_Frame(self)
        quit_button = tk.Button(self, text="exit", font=("Courier", 10), bg="#F5F2C8", highlightthickness=0, command=self.destroy)
        quit_button.pack(anchor="s")
                
        # Programm zu laufen bringen:
        zeige_startfenster(self, "SpiderWeb", "Willkommen, ich bin dein neuer Helfer für den Alltag.\nBist du bereit, eine Routine zu finden\nund nie wieder deine wichtigsten Aufgaben zu vergessen?")
        self.mainloop()



